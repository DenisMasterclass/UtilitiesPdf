            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/ImportarProjetosPorPastaRequest"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/ImportarProjetosPorPastaRequest"
              }
            }
