          "nomeArquivo": {
            "type": "string",
            "nullable": true
          },
          "origem": {
            "type": "string",
            "nullable": true
          },
          "sucesso": {
            "type": "boolean"
          },
          "registrosAfetados": {
            "type": "integer",
            "format": "int32"
          },
          "mensagem": {
            "type": "string",
            "nullable": true
          },
          "dataProcessamento": {
            "type": "string",
            "format": "date-time"
          }
        },
        "additionalProperties": false
      },
      "ImportacaoPdfLoteResultado": {
        "type": "object",
        "properties": {
          "totalArquivos": {
            "type": "integer",
            "format": "int32"
          },
          "arquivosProcessadosComSucesso": {
            "type": "integer",
            "format": "int32"
          },
          "arquivosComErro": {
            "type": "integer",
            "format": "int32"
          },
          "resultados": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ImportacaoPdfResultado"
            },
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "ImportacaoPdfResultado": {
        "type": "object",
        "properties": {
          "nomeArquivo": {
            "type": "string",
            "nullable": true
          },
          "sucesso": {
            "type": "boolean"
          },
          "registrosAfetados": {
            "type": "integer",
            "format": "int32"
          },
          "mensagem": {
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
