@inherits LayoutComponentBase

<div class="shell">
    <header class="topbar">
        <div class="brand-wrap">
            <div>
                <p class="eyebrow">UtilitiesPdf</p>
                <h1>Portal de Importacao</h1>
            </div>

            <nav class="main-nav">
                <NavLink href="/" Match="NavLinkMatch.All">Inicio</NavLink>
                <NavLink href="/importacoes">Executar importacoes</NavLink>
                <NavLink href="/follow-up">Follow-up</NavLink>
            </nav>
        </div>

        <div class="porto-logo" aria-label="Porto Seguro">
            <svg viewBox="0 0 120 120" role="img" aria-hidden="true">
                <defs>
                    <linearGradient id="portoIconBlue" x1="0" y1="0" x2="1" y2="1">
                        <stop offset="0%" stop-color="#87CEFA" />
                        <stop offset="45%" stop-color="#00BFFF" />
                        <stop offset="100%" stop-color="#1E90FF" />
                    </linearGradient>
                </defs>
                <rect x="6" y="6" width="108" height="108" rx="10" fill="url(#portoIconBlue)" />
                <path d="M20 24 C45 18, 72 22, 93 38 C72 31, 45 31, 23 35 Z" fill="#F7FCFF" />
                <path d="M22 42 C48 35, 77 39, 97 56 C76 48, 48 47, 24 53 Z" fill="#F7FCFF" />
                <path d="M22 62 C49 54, 80 58, 100 77 C78 68, 50 67, 25 74 Z" fill="#F7FCFF" />
                <path d="M21 83 C50 73, 82 76, 100 94 C80 86, 52 86, 27 96 Z" fill="#F7FCFF" />
            </svg>
        </div>
    </header>

    <main class="content">
        @Body
    </main>
</div>
